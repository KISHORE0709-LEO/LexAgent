# Copy this file to .env and fill in your real keys

# Google AI Studio - FREE at https://aistudio.google.com/apikey
# Used for: LLM reasoning (Gemini 1.5 Flash) + embeddings (text-embedding-004)
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-studio-key-here

# Qdrant Cloud - free cluster at https://cloud.qdrant.io
QDRANT_URL=https://xxxxxxxx.cloud.qdrant.io:6333
QDRANT_API_KEY=xxxxxxxx

# Enkrypt AI - https://app.enkryptai.com  (free trial key, optional)
# If you leave this as "xxxxxxxx", the app will skip the remote guard check
# and only run the local citation cross-check instead.
ENKRYPTAI_API_KEY=xxxxxxxx
ENKRYPTAI_BASE_URL=https://api.enkryptai.com

# AWS Bedrock Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key-id-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key-here
AWS_REGION=us-east-1

PORT=3000
